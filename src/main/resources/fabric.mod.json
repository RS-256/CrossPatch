{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "mod that mixin at some client mod",
  "authors": [
    "RS256"
  ],
  "contact": {
    "homepage": "https://stonecutter.kikugie.dev/",
    "sources": "https://github.com/RS-256/CrossPatch"
  },
  "license": "LGPL-3.0-only",
  "icon": "assets/crosspatch/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "com.rs256.crossPatch.client.CrossPatchClient"
    ],
    "modmenu": [
      "com.rs256.crossPatch.client.compat.modmenu.ModMenuIntegration"
    ]
  },
  "mixins": [
    {
      "config": "crossPatchClient.mixins.json",
      "environment": "client"
    }
  ],
  "accessWidener": "${accesswidener}",
  "depends": {
    "fabricloader": "${fabricLoader}",
    "minecraft": "${minecraft}",
    "${fabricApiKey}": "${fabricAPI}",
    "malilib": "${malilib}"
  },
  "suggests": {
    "modmenu": "${modmenu}",
    "litematica": "${litematica}",
    "itemscroller": "${itemscroller}",
    "tweakermore": "${tweakermore}",
    "flashback": "${flashback}",
    "bobby": "${bobby}"
  }
}
