{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "This is an example description! Tell everyone what your mod is about!",
  "authors": [
    "Me!"
  ],
  "contact": {
    "homepage": "https://stonecutter.kikugie.dev/",
    "sources": "https://codeberg.org/stonecutter/template-fabric"
  },
  "license": "CC0-1.0",
  "icon": "assets/crossPatch/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.rs256.crossPatch.CrossPatch"
    ],
    "client": [
      "com.rs256.crossPatch.client.CrossPatchModClient"
    ]
  },
  "mixins": [
    "crossPatch.mixins.json",
    {
      "config": "crossPatchClient.mixins.json",
      "environment": "client"
    }
  ],
  "accessWidener": "${accesswidener}",
  "depends": {
    "fabricloader": "${fabricLoader}",
    "minecraft": "${minecraft}",
    "${fabricApiKey}": "${fabricAPI}",
    "malilib": "${malilib}"
  },
  "suggests": {
    "modmenu": "${modmenu}",
    "litematica": "${litematica}"
  }
}